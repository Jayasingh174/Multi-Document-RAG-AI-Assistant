# =========================
# App Settings
# =========================
APP_NAME=multi-doc-rag
APP_ENV=development
DEBUG=true

# =========================
# Upload + Storage
# =========================
UPLOAD_DIR=uploads
VECTOR_STORE_DIR=vectorstore

# =========================
# Embedding Model
# =========================
EMBEDDING_MODEL=BAAI/bge-base-en
EMBEDDING_DIMENSION=768

# =========================
# Retrieval
# =========================
TOP_K=5

# =========================
# Chunking
# =========================
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MIN_CHUNK_LENGTH=50

# =========================
# Ollama
# =========================
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=512